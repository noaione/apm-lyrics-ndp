{
    "$schema": "https://raw.githubusercontent.com/navidrome/navidrome/master/plugins/manifest-schema.json",
    "name": "Apple Music Lyrics Fetcher",
    "author": "noaione",
    "version": "0.1.2",
    "description": "Automatically fetch Apple Music Lyrics when needed",
    "config": {
        "schema": {
            "type": "object",
            "properties": {
                "media_token": {
                    "type": "string",
                    "title": "APM Media Token",
                    "description": "Your Apple Music media-user-token, required for this to work. Login to Apple Music Beta"
                },
                "user_agent": {
                    "type": "string",
                    "title": "User Agent",
                    "description": "The User-Agent used for logging in"
                },
                "storefront": {
                    "type": "string",
                    "title": "Storefront",
                    "description": "The account storefront, must be correct"
                },
                "cache_days": {
                    "type": "number",
                    "title": "Cache Days",
                    "description": "How many days we should cache the lyrics",
                    "default": 7,
                    "minimum": 1,
                    "maximum": 30
                },
                "skip_cache": {
                    "type": "boolean",
                    "title": "Skip Cache",
                    "description": "Skip the cache and always fetch the lyrics from Apple Music, useful to debug/update",
                    "default": false
                },
                "translation_language": {
                    "type": "string",
                    "title": "Translation language",
                    "default": "en-GB",
                    "oneOf": [
                        { "const": "ar", "title": "Arabic" },
                        { "const": "ca", "title": "Catalan" },
                        { "const": "zh-Hans-CN", "title": "Chinese (Simplified)" },
                        {
                            "const": "zh-Hant-HK",
                            "title": "Chinese (Traditional, Hong Kong)"
                        },
                        {
                            "const": "zh-Hant-TW",
                            "title": "Chinese (Traditional, Taiwan)"
                        },
                        { "const": "hr", "title": "Croatian" },
                        { "const": "cs", "title": "Czech" },
                        { "const": "da", "title": "Danish" },
                        { "const": "nl", "title": "Dutch" },
                        { "const": "en-AU", "title": "English (Australia)" },
                        { "const": "en-CA", "title": "English (Canada)" },
                        { "const": "en-GB", "title": "English (UK)" },
                        { "const": "en-US", "title": "English (US)" },
                        { "const": "fi", "title": "Finnish" },
                        { "const": "fr-FR", "title": "French" },
                        { "const": "fr-CA", "title": "French (Canada)" },
                        { "const": "de-DE", "title": "German" },
                        { "const": "de-CH", "title": "German (Switzerland)" },
                        { "const": "el", "title": "Greek" },
                        { "const": "he", "title": "Hebrew" },
                        { "const": "hi", "title": "Hindi" },
                        { "const": "hu", "title": "Hungarian" },
                        { "const": "id", "title": "Indonesian" },
                        { "const": "it", "title": "Italian" },
                        { "const": "ja", "title": "Japanese" },
                        { "const": "ko", "title": "Korean" },
                        { "const": "ms", "title": "Malay" },
                        { "const": "nb", "title": "Norwegian Bokmål" },
                        { "const": "pl", "title": "Polish" },
                        { "const": "pt-BR", "title": "Portuguese (Brazil)" },
                        { "const": "pt-PT", "title": "Portuguese (Portugal)" },
                        { "const": "ro", "title": "Romanian" },
                        { "const": "ru", "title": "Russian" },
                        { "const": "sk", "title": "Slovak" },
                        { "const": "es-MX", "title": "Spanish (Mexico)" },
                        { "const": "es-ES", "title": "Spanish (Spain)" },
                        { "const": "sv", "title": "Swedish" },
                        { "const": "th", "title": "Thai" },
                        { "const": "tr", "title": "Turkish" },
                        { "const": "uk", "title": "Ukrainian" },
                        { "const": "vi", "title": "Vietnamese" }
                    ],
                    "description": "Language the translation should be in. Only used when translations are included."
                }
            },
            "uiSchema": {
                "type": "VerticalLayout",
                "elements": [
                    {
                        "type": "Label",
                        "text": "Account"
                    },
                    {
                        "type": "VerticalLayout",
                        "elements": [
                            {
                                "type": "Control",
                                "scope": "#/properties/media_token",
                                "options": {
                                    "size": 9
                                }
                            },
                            {
                                "type": "Control",
                                "scope": "#/properties/user_agent",
                                "options": {
                                    "size": 9
                                }
                            },
                            {
                                "type": "Control",
                                "scope": "#/properties/storefront",
                                "options": {
                                    "size": 3
                                }
                            }
                        ]
                    },
                    {
                        "type": "Label",
                        "text": "Settings"
                    },
                    {
                        "type": "VerticalLayout",
                        "elements": [
                            {
                                "type": "Control",
                                "scope": "#/properties/translation_language"
                            },
                            {
                                "type": "Control",
                                "scope": "#/properties/cache_days",
                                "options": {
                                    "size": 3
                                }
                            },
                            {
                                "type": "Control",
                                "scope": "#/properties/skip_cache"
                            }
                        ]
                    }
                ]
            }
        }
    },
    "permissions": {
        "http": {
            "reason": "Communicate with Apple Music website and API",
            "requiredHosts": [
                "amp-api.music.apple.com",
                "beta.music.apple.com",
                "music.apple.com"
            ]
        },
        "kvstore": {
            "reason": "Store TTML lyrics for fast-lookup",
            "maxSize": "250MB"
        },
        "library": {
            "reason": "Raw access the file for tag lookup",
            "filesystem": true
        },
        "cache": {
            "reason": "Cache used for the JWT token from the webpage"
        }
    }
}
